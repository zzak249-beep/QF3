# ── API Keys ──────────────────────────────────────────
BINGX_API_KEY=tu_api_key
BINGX_SECRET=tu_secret
TG_TOKEN=tu_bot_token
TG_CHAT_ID=-100xxxxxxxxx

# ── Modo ──────────────────────────────────────────────
# SIGNAL = solo alertas Telegram | LIVE = opera real
MODE=SIGNAL

# ── Símbolos ──────────────────────────────────────────
SYMBOLS_MODE=AUTO
MIN_VOLUME_USDT=50000000
MAX_SYMBOLS=25

# ── Riesgo ────────────────────────────────────────────
LEVERAGE=5
RISK_PCT=0.5
MAX_DD_PCT=5.0
MAX_POSITIONS=5
TP_RR=2.0

# ── Sesiones ──────────────────────────────────────────
SESSIONS=NY,LDN
LOOP_INTERVAL=30
SCANNER_INTERVAL=3600

# ── Umbrales señal ────────────────────────────────────
SCORE_THR_LONG=0.63
SCORE_THR_SHORT=0.63
DECAY_THR=0.65
MIN_CONV_STD=6
MIN_CONV_FUEL=7
MIN_CONV_SUP=8

# ── Performance ───────────────────────────────────────
MIN_PF=1.5
PF_WINDOW=20

# ── v5: L13 Order Flow Imbalance ──────────────────────
OFI_LEVELS=5
OFI_THR_WEAK=0.3
OFI_THR_STRONG=0.5

# ── v5: L14 Funding Rate ──────────────────────────────
FR_BULL_THR=0.0001
FR_BEAR_THR=-0.0001
FR_EXTREME_THR=0.005

# ── v5: L15 Open Interest Delta ───────────────────────
OI_DELTA_THR=0.005

# ── v5: Trailing SL ───────────────────────────────────
# Se activa cuando el precio se mueve TRAIL_ACTIVATE_ATR × ATR a favor
# Trail distance = TRAIL_ATR_MULT × ATR
TRAIL_ACTIVATE_ATR=1.0
TRAIL_ATR_MULT=1.5

# ── v5: Maker Orders (−73% fees) ──────────────────────
# true = intenta limit post-only, fallback a market si no llena
USE_MAKER_ORDERS=true
MAKER_TIMEOUT=30
MAKER_OFFSET_PCT=0.02

# ── v5: Multi-TF ──────────────────────────────────────
USE_1H_FILTER=true
MULTI_TF_BONUS=2
